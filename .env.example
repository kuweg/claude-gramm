# engram environment — copy to `.env` and fill in, or `export` these in your shell.
# Secrets live in the environment ONLY, never in config.toml or the state DB (DESIGN §5, §8).

# Required: your Anthropic API key. The Anthropic SDK reads this automatically.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the config file location (default: platform config dir,
# e.g. ~/.config/engram/config.toml on Linux).
# ENGRAM_CONFIG=/path/to/config.toml
