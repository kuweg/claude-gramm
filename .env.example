# engram environment — copy to `.env` and fill in, or `export` these in your shell.
# Secrets live in the environment ONLY, never in config.toml or the state DB (DESIGN §5, §8).

# --- Model / provider selection (overrides config.toml) -------------------
# ENGRAM_MODEL picks the distillation model; the provider is inferred from it
# (claude-* → Anthropic, gpt-*/o* → OpenAI, deepseek-* → DeepSeek). Set
# ENGRAM_PROVIDER only to force a provider for a non-standard model id.
#
# ENGRAM_MODEL=claude-sonnet-4-6      # default; or claude-haiku-4-5 (cheaper)
# ENGRAM_MODEL=gpt-4o                 # OpenAI / ChatGPT
# ENGRAM_MODEL=deepseek-chat          # DeepSeek
# ENGRAM_PROVIDER=anthropic|openai|deepseek

# --- API keys (only the one for your chosen provider is required) ---------
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...

# --- Optional ------------------------------------------------------------
# Override the config file location (default: ~/.config/engram/config.toml).
# ENGRAM_CONFIG=/path/to/config.toml
